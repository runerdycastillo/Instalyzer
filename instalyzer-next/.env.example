# Microsoft Graph app-only mail delivery for the contact form.
# Copy these into .env.local once your Entra app registration is ready.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_SENDER_USER=support@instalyzer.app
CONTACT_SUPPORT_TO=support@instalyzer.app
CONTACT_SUPPORT_SUBJECT_PREFIX=[Instalyzer Contact]
DESKTOP_LINK_CAPTURE_TO=support@instalyzer.app

# Firebase web app config.
# Public Firebase web config is safe to expose in the browser, but keep real
# project values in .env.local or deployment secrets.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Admin config for server-side session cookies.
# Never expose these values to client components.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_AUTH_SESSION_COOKIE_NAME=instalyzer_session
